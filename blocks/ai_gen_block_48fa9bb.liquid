{% doc %}
  @prompt
    I would like a price blocks in this blocks  where the product section displays both the price and compare-at price, along with the percentage saved. the vlock name should be "Myro Price"
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-myro-price-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-myro-price-container-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.alignment }};
    gap: {{ block.settings.spacing }}px;
    flex-wrap: wrap;
  }

  .ai-myro-price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: baseline;
    gap: {{ block.settings.price_spacing }}px;
  }

  .ai-myro-current-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.price_color }};
    line-height: 1.2;
  }

  .ai-myro-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    line-height: 1.2;
  }

  .ai-myro-savings-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    line-height: 1;
  }

  .ai-myro-price-empty-{{ ai_gen_id }} {
    color: #999;
    font-size: 14px;
    font-style: italic;
  }
{% endstyle %}

<div class="ai-myro-price-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product %}
    {% assign current_variant = product.selected_or_first_available_variant %}
    {% assign compare_at_price = current_variant.compare_at_price %}
    {% assign price = current_variant.price %}

    <div class="ai-myro-price-container-{{ ai_gen_id }}">
      <div class="ai-myro-price-wrapper-{{ ai_gen_id }}">
        <div class="ai-myro-current-price-{{ ai_gen_id }}">
          {{ price | money }}
        </div>

        {% if compare_at_price and compare_at_price > price %}
          <div class="ai-myro-compare-price-{{ ai_gen_id }}">
            {{ compare_at_price | money }}
          </div>
        {% endif %}
      </div>

      {% if compare_at_price and compare_at_price > price and block.settings.show_savings %}
        {% assign savings = compare_at_price | minus: price %}
        {% assign savings_percent = savings | times: 100.0 | divided_by: compare_at_price | round %}

        <div class="ai-myro-savings-badge-{{ ai_gen_id }}">
          {% if block.settings.savings_format == 'percentage' %}
            {{ block.settings.savings_text }} {{ savings_percent }}%
          {% elsif block.settings.savings_format == 'amount' %}
            {{ block.settings.savings_text }} {{ savings | money }}
          {% else %}
            {{ block.settings.savings_text }} {{ savings_percent }}% ({{ savings | money }})
          {% endif %}
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-myro-price-empty-{{ ai_gen_id }}">
      Product price will display here
    </div>
  {% endif %}
</div>

