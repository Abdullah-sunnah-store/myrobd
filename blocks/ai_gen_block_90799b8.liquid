{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-top-selling-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-top-selling-slider__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-top-selling-slider__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-top-selling-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-top-selling-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-top-selling-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-top-selling-slider__card-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: calc((100% - (3 * {{ block.settings.card_gap }}px)) / 4);
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    position: relative;
    text-align: center;
    transition: transform 0.3s ease;
  }

  .ai-top-selling-slider__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-top-selling-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 20px;
  }

  .ai-top-selling-slider__background-shape-{{ ai_gen_id }} {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 85%;
    height: 100%;
    border-radius: {{ block.settings.shape_border_radius }}px;
    z-index: 0;
  }

  .ai-top-selling-slider__image-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }

  .ai-top-selling-slider__image-placeholder-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-top-selling-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-top-selling-slider__premium-{{ ai_gen_id }} {
    font-size: {{ block.settings.premium_text_size }}px;
    font-weight: 300;
    color: {{ block.settings.premium_text_color }};
    margin: 0 0 8px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-top-selling-slider__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-top-selling-slider__product-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
  }

  .ai-top-selling-slider__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 15px;
    margin-top: 30px;
  }

  .ai-top-selling-slider__nav-button-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-top-selling-slider__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-top-selling-slider__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-top-selling-slider__nav-button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: {{ block.settings.nav_icon_color }};
  }

  @media screen and (max-width: 1024px) {
    .ai-top-selling-slider__card-{{ ai_gen_id }} {
      width: calc((100% - {{ block.settings.card_gap }}px) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-top-selling-slider__card-{{ ai_gen_id }} {
      width: calc((100% - ({{ block.settings.card_gap }}px * 0.5)) / 1.5);
    }

    .ai-top-selling-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-top-selling-slider__container-{{ ai_gen_id }} {
      padding: 0 15px;
    }
  }
{% endstyle %}

<top-selling-slider-{{ ai_gen_id }} class="ai-top-selling-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-top-selling-slider__container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <div class="ai-top-selling-slider__header-{{ ai_gen_id }}">
        <h2 class="ai-top-selling-slider__title-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-top-selling-slider__wrapper-{{ ai_gen_id }}">
      <div class="ai-top-selling-slider__track-{{ ai_gen_id }}" data-slider-track>
        {% if block.settings.collection != blank %}
          {% for product in block.settings.collection.products limit: block.settings.products_limit %}
            <div class="ai-top-selling-slider__card-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-top-selling-slider__product-link-{{ ai_gen_id }}">
                <div class="ai-top-selling-slider__image-wrapper-{{ ai_gen_id }}">
                  {% liquid
                    assign color_index = forloop.index | modulo: 5
                    case color_index
                      when 0
                        assign shape_color = block.settings.shape_color_1
                      when 1
                        assign shape_color = block.settings.shape_color_2
                      when 2
                        assign shape_color = block.settings.shape_color_3
                      when 3
                        assign shape_color = block.settings.shape_color_4
                      when 4
                        assign shape_color = block.settings.shape_color_5
                    endcase
                  %}
                  <div class="ai-top-selling-slider__background-shape-{{ ai_gen_id }}" style="background-color: {{ shape_color }};"></div>
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-top-selling-slider__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="600"
                    >
                  {% else %}
                    <div class="ai-top-selling-slider__image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <p class="ai-top-selling-slider__premium-{{ ai_gen_id }}">{{ block.settings.premium_text }}</p>
                <h3 class="ai-top-selling-slider__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              </a>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..8) %}
            <div class="ai-top-selling-slider__card-{{ ai_gen_id }}">
              <div class="ai-top-selling-slider__image-wrapper-{{ ai_gen_id }}">
                {% liquid
                  assign color_index = forloop.index | modulo: 5
                  case color_index
                    when 0
                      assign shape_color = block.settings.shape_color_1
                    when 1
                      assign shape_color = block.settings.shape_color_2
                    when 2
                      assign shape_color = block.settings.shape_color_3
                    when 3
                      assign shape_color = block.settings.shape_color_4
                    when 4
                      assign shape_color = block.settings.shape_color_5
                  endcase
                %}
                <div class="ai-top-selling-slider__background-shape-{{ ai_gen_id }}" style="background-color: {{ shape_color }};"></div>
                <div class="ai-top-selling-slider__image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
              <p class="ai-top-selling-slider__premium-{{ ai_gen_id }}">{{ block.settings.premium_text }}</p>
              <h3 class="ai-top-selling-slider__product-title-{{ ai_gen_id }}">Product Title {{ i }}</h3>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="ai-top-selling-slider__nav-{{ ai_gen_id }}">
      <button class="ai-top-selling-slider__nav-button-{{ ai_gen_id }}" data-prev aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
        </svg>
      </button>
      <button class="ai-top-selling-slider__nav-button-{{ ai_gen_id }}" data-next aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
        </svg>
      </button>
    </div>
  </div>
</top-selling-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TopSellingSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.track = this.querySelector('[data-slider-track]');
        this.cards = this.track.querySelectorAll('.ai-top-selling-slider__card-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.cardGap = {{ block.settings.card_gap }};
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.setupEventListeners();
        this.updateButtons();
        if ({{ block.settings.autoplay }}) {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prev());
        this.nextButton.addEventListener('click', () => this.next());

        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
          this.stopAutoplay();
        });

        this.track.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.track.addEventListener('touchend', () => {
          if (!isDragging) return;
          const diff = startX - currentX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.next();
            } else {
              this.prev();
            }
          }
          isDragging = false;
          if ({{ block.settings.autoplay }}) {
            this.startAutoplay();
          }
        });
      }

      getCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) return 1.5;
        if (width <= 1024) return 2;
        return 4;
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      next() {
        const cardsPerView = this.getCardsPerView();
        const maxIndex = Math.ceil(this.cards.length - cardsPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      updateSlider() {
        const cardWidth = this.cards[0].offsetWidth;
        const offset = this.currentIndex * (cardWidth + this.cardGap);
        this.track.style.transform = `translateX(-${offset}px)`;
        this.updateButtons();
      }

      updateButtons() {
        const cardsPerView = this.getCardsPerView();
        const maxIndex = Math.ceil(this.cards.length - cardsPerView);
        
        this.prevButton.disabled = this.currentIndex === 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          const cardsPerView = this.getCardsPerView();
          const maxIndex = Math.ceil(this.cards.length - cardsPerView);
          
          if (this.currentIndex >= maxIndex) {
            this.currentIndex = 0;
          } else {
            this.currentIndex++;
          }
          this.updateSlider();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('top-selling-slider-{{ ai_gen_id }}', TopSellingSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
