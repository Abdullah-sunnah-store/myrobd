{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-size-chart-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 20px 0px;
    background-color: {{ block.settings.background_color }};
  }
  .ai-size-chart-header-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-size-chart-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
    font-family: var(--font-heading-family);
  }

  .ai-size-chart-disclaimer-{{ ai_gen_id }} {
    font-size: {{ block.settings.disclaimer_size }}px;
    color: {{ block.settings.disclaimer_color }};
    margin: 0;
  }

  .ai-size-chart-tabs-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
  }

  .ai-size-chart-tab-{{ ai_gen_id }} {
    padding: 12px 32px;
    background-color: {{ block.settings.tab_inactive_bg }};
    color: {{ block.settings.tab_inactive_text }};
    border: 2px solid {{ block.settings.tab_inactive_border }};
    border-radius: {{ block.settings.tab_border_radius }}px;
    font-size: {{ block.settings.tab_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-size-chart-tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_bg }};
  }

  .ai-size-chart-tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_bg }};
    color: {{ block.settings.tab_active_text }};
    border-color: {{ block.settings.tab_active_border }};
  }

  .ai-size-chart-table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-size-chart-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_bg_color }};
    
  }
  @media screen and (min-width: 749px){
    .ai-size-chart-table-{{ ai_gen_id }} {
      min-width: 500px;
    }
  }

  .ai-size-chart-table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_bg_color }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} th {
    padding: 16px;
    text-align: left;
    font-weight: 700;
    font-size: {{ block.settings.header_font_size }}px;
    color: {{ block.settings.header_text_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-size-chart-table-{{ ai_gen_id }} td {
    padding: 14px 16px;
    font-size: {{ block.settings.cell_font_size }}px;
    color: {{ block.settings.text_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }
  .ai-size-chart-table-{{ ai_gen_id }} tr td:first-child {
    color:rgb(242, 48, 134);
    font-weight: 700;
    
  }

  .ai-size-chart-table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-size-chart-table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  .ai-size-chart-hidden-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-size-chart-{{ ai_gen_id }} {
      padding: 15px 0px;
    }
    .ai-size-chart-table-{{ ai_gen_id }} th{
      font-size:12px;
      padding:10px;
    }
    .ai-size-chart-table-{{ ai_gen_id }} td {
      font-size:10px;
      padding:10px 15px;
    }
    .ai-size-chart-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-size-chart-tabs-{{ ai_gen_id }} {
      gap: 8px;
    }

    .ai-size-chart-tab-{{ ai_gen_id }} {
      padding: 10px 24px;
      font-size: calc({{ block.settings.tab_font_size }}px * 0.9);
    }

    .ai-size-chart-table-wrapper-{{ ai_gen_id }} {
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
  }
{% endstyle %}

<size-chart-{{ ai_gen_id }} class="ai-size-chart-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-size-chart-container-{{ ai_gen_id }}">
    <div class="ai-size-chart-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-size-chart-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.disclaimer != blank %}
        <p class="ai-size-chart-disclaimer-{{ ai_gen_id }}">{{ block.settings.disclaimer }}</p>
      {% endif %}
    </div>

    <div class="ai-size-chart-table-wrapper-{{ ai_gen_id }}">
      <table class="ai-size-chart-table-{{ ai_gen_id }}">
        <thead>
          <tr>
            <th>{{ block.settings.column_1_header }}</th>
            <th>{{ block.settings.column_2_header }}</th>
            <th>{{ block.settings.column_3_header }}</th>
            <th>{{ block.settings.column_4_header }}</th>
          </tr>
        </thead>
        <tbody>
          {% if block.settings.size_1_label != blank %}
            <tr>
              <td>{{ block.settings.size_1_label }}</td>
              <td data-inch="{{ block.settings.size_1_chest_inch }}" data-cm="{{ block.settings.size_1_chest_cm }}">
                {{ block.settings.size_1_chest_inch }}
              </td>
              <td data-inch="{{ block.settings.size_1_length_inch }}" data-cm="{{ block.settings.size_1_length_cm }}">
                {{ block.settings.size_1_length_inch }}
              </td>
              <td data-inch="{{ block.settings.size_1_sleeve_inch }}" data-cm="{{ block.settings.size_1_sleeve_cm }}">
                {{ block.settings.size_1_sleeve_inch }}
              </td>
            </tr>
          {% endif %}
          {% if block.settings.size_2_label != blank %}
            <tr>
              <td>{{ block.settings.size_2_label }}</td>
              <td data-inch="{{ block.settings.size_2_chest_inch }}" data-cm="{{ block.settings.size_2_chest_cm }}">
                {{ block.settings.size_2_chest_inch }}
              </td>
              <td data-inch="{{ block.settings.size_2_length_inch }}" data-cm="{{ block.settings.size_2_length_cm }}">
                {{ block.settings.size_2_length_inch }}
              </td>
              <td data-inch="{{ block.settings.size_2_sleeve_inch }}" data-cm="{{ block.settings.size_2_sleeve_cm }}">
                {{ block.settings.size_2_sleeve_inch }}
              </td>
            </tr>
          {% endif %}
          {% if block.settings.size_3_label != blank %}
            <tr>
              <td>{{ block.settings.size_3_label }}</td>
              <td data-inch="{{ block.settings.size_3_chest_inch }}" data-cm="{{ block.settings.size_3_chest_cm }}">
                {{ block.settings.size_3_chest_inch }}
              </td>
              <td data-inch="{{ block.settings.size_3_length_inch }}" data-cm="{{ block.settings.size_3_length_cm }}">
                {{ block.settings.size_3_length_inch }}
              </td>
              <td data-inch="{{ block.settings.size_3_sleeve_inch }}" data-cm="{{ block.settings.size_3_sleeve_cm }}">
                {{ block.settings.size_3_sleeve_inch }}
              </td>
            </tr>
          {% endif %}
          {% if block.settings.size_4_label != blank %}
            <tr>
              <td>{{ block.settings.size_4_label }}</td>
              <td data-inch="{{ block.settings.size_4_chest_inch }}" data-cm="{{ block.settings.size_4_chest_cm }}">
                {{ block.settings.size_4_chest_inch }}
              </td>
              <td data-inch="{{ block.settings.size_4_length_inch }}" data-cm="{{ block.settings.size_4_length_cm }}">
                {{ block.settings.size_4_length_inch }}
              </td>
              <td data-inch="{{ block.settings.size_4_sleeve_inch }}" data-cm="{{ block.settings.size_4_sleeve_cm }}">
                {{ block.settings.size_4_sleeve_inch }}
              </td>
            </tr>
          {% endif %}
          {% if block.settings.size_5_label != blank %}
            <tr>
              <td>{{ block.settings.size_5_label }}</td>
              <td data-inch="{{ block.settings.size_5_chest_inch }}" data-cm="{{ block.settings.size_5_chest_cm }}">
                {{ block.settings.size_5_chest_inch }}
              </td>
              <td data-inch="{{ block.settings.size_5_length_inch }}" data-cm="{{ block.settings.size_5_length_cm }}">
                {{ block.settings.size_5_length_inch }}
              </td>
              <td data-inch="{{ block.settings.size_5_sleeve_inch }}" data-cm="{{ block.settings.size_5_sleeve_cm }}">
                {{ block.settings.size_5_sleeve_inch }}
              </td>
            </tr>
          {% endif %}
          {% if block.settings.size_6_label != blank %}
            <tr>
              <td>{{ block.settings.size_6_label }}</td>
              <td data-inch="{{ block.settings.size_6_chest_inch }}" data-cm="{{ block.settings.size_6_chest_cm }}">
                {{ block.settings.size_6_chest_inch }}
              </td>
              <td data-inch="{{ block.settings.size_6_length_inch }}" data-cm="{{ block.settings.size_6_length_cm }}">
                {{ block.settings.size_6_length_inch }}
              </td>
              <td data-inch="{{ block.settings.size_6_sleeve_inch }}" data-cm="{{ block.settings.size_6_sleeve_cm }}">
                {{ block.settings.size_6_sleeve_inch }}
              </td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
</size-chart-{{ ai_gen_id }}>



