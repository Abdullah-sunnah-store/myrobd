{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-icon-button__link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.icon_spacing }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;

    {% if block.settings.use_gradient %}
      background: linear-gradient(
        {{ block.settings.gradient_angle }}deg,
        {{ block.settings.gradient_color_1 }},
        {{ block.settings.gradient_color_2 }}
      );
      color: {{ block.settings.gradient_text_color }};
    {% else %}
      background-color: {{ block.settings.button_color }};
      color: {{ block.settings.button_text_color }};
    {% endif %}
  }

  .ai-icon-button__link-{{ ai_gen_id }}:hover {
    {% if block.settings.use_gradient %}
      background: linear-gradient(
        {{ block.settings.gradient_angle }}deg,
        {{ block.settings.gradient_hover_color_1 }},
        {{ block.settings.gradient_hover_color_2 }}
      );
      color: {{ block.settings.gradient_hover_text_color }};
    {% else %}
      background-color: {{ block.settings.button_hover_color }};
      color: {{ block.settings.button_hover_text_color }};
    {% endif %}
  }

  .ai-icon-button__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-button__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-icon-button__text-{{ ai_gen_id }} {
    line-height: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-icon-button__link-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-icon-button-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <a href="{{ block.settings.button_link }}" class="ai-icon-button__link-{{ ai_gen_id }}" target="_blank">
    {% if block.settings.show_icon and block.settings.icon_position == 'before' %}
      <span class="ai-icon-button__icon-{{ ai_gen_id }}">
        {{ block.settings.icon_svg }}
      </span>
    {% endif %}
    
    {% if block.settings.button_text != blank %}
      <span class="ai-icon-button__text-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
    {% endif %}
    
    {% if block.settings.show_icon and block.settings.icon_position == 'after' %}
      <span class="ai-icon-button__icon-{{ ai_gen_id }}">
        {{ block.settings.icon_svg }}
      </span>
    {% endif %}
  </a>
</div>

{% schema %}
{
  "name": "Icon button",
  "settings": [
    {
      "type": "header",
      "content": "Button content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show icon",
      "default": true
    },
    {
      "type": "html",
      "id": "icon_svg",
      "label": "Icon SVG code",
      "default": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg>"
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "Icon position",
      "options": [
        {
          "value": "before",
          "label": "Before text"
        },
        {
          "value": "after",
          "label": "After text"
        }
      ],
      "default": "before"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use gradient background",
      "default": false
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Background color",
      "default": "#f23086"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Gradient colors"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient color 1",
      "default": "#f23086"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient color 2",
      "default": "#ff6b9d"
    },
    {
      "type": "color",
      "id": "gradient_text_color",
      "label": "Gradient text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 15,
      "unit": "deg",
      "default": 135
    },
    {
      "type": "header",
      "content": "Gradient hover colors"
    },
    {
      "type": "color",
      "id": "gradient_hover_color_1",
      "label": "Hover gradient color 1",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "gradient_hover_color_2",
      "label": "Hover gradient color 2",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "gradient_hover_text_color",
      "label": "Hover gradient text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "button_font",
      "label": "Font",
      "default": "montserrat_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Icon button"
    }
  ]
}
{% endschema %}