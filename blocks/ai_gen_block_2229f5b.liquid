{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-slider-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }
  .ai-hero-slider-{{ ai_gen_id }} a img{
    transition: transform .3s ease;
  }
  .ai-hero-slider-{{ ai_gen_id }} a:hover img{
    transform: scale(1.05);
  }
  .ai-hero-slider-{{ ai_gen_id }} a:hover {
    opacity: .7;
}

  .ai-hero-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-hero-slider-slide-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: none;
  }

  .ai-hero-slider-slide-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-hero-slider-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    text-decoration: none;
  }

  .ai-hero-slider-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-slider-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-slider-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-slider-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_background_color }};
    border: none;
    width: {{ block.settings.nav_size }}px;
    height: {{ block.settings.nav_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease;
  }

  .ai-hero-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_background_color }};
  }

  .ai-hero-slider-nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_size }}px * 0.5);
    height: calc({{ block.settings.nav_size }}px * 0.5);
    stroke: {{ block.settings.nav_icon_color }};
  }

  .ai-hero-slider-nav-{{ ai_gen_id }}:hover svg {
    stroke: {{ block.settings.nav_hover_icon_color }};
  }

  .ai-hero-slider-nav-prev-{{ ai_gen_id }} {
    left: {{ block.settings.nav_offset }}px;
  }

  .ai-hero-slider-nav-next-{{ ai_gen_id }} {
    right: {{ block.settings.nav_offset }}px;
  }

  .ai-hero-slider-pagination-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.pagination_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .ai-hero-slider-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-hero-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-hero-slider-dot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.dot_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slider-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-hero-slider-nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_size }}px * 0.8);
      height: calc({{ block.settings.nav_size }}px * 0.8);
    }

    .ai-hero-slider-nav-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.nav_size }}px * 0.4);
      height: calc({{ block.settings.nav_size }}px * 0.4);
    }

    .ai-hero-slider-nav-prev-{{ ai_gen_id }} {
      left: calc({{ block.settings.nav_offset }}px * 0.5);
    }

    .ai-hero-slider-nav-next-{{ ai_gen_id }} {
      right: calc({{ block.settings.nav_offset }}px * 0.5);
    }

    .ai-hero-slider-pagination-{{ ai_gen_id }} {
      bottom: calc({{ block.settings.pagination_offset }}px * 0.7);
    }

    .ai-hero-slider-dot-{{ ai_gen_id }} {
      width: calc({{ block.settings.dot_size }}px * 0.8);
      height: calc({{ block.settings.dot_size }}px * 0.8);
    }
  }
{% endstyle %}

<hero-slider-{{ ai_gen_id }}
  class="ai-hero-slider-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-transition="{{ block.settings.transition_effect }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-slider-wrapper-{{ ai_gen_id }}">
    {% liquid
      assign slides = ''
      assign slide_count = 0

      for i in (1..5)
        assign image_key = 'slide_' | append: i | append: '_image'
        assign link_key = 'slide_' | append: i | append: '_link'
        assign alt_key = 'slide_' | append: i | append: '_alt_text'
        
        assign slide_image = block.settings[image_key]
        
        if slide_image != blank
          assign slide_count = slide_count | plus: 1
        endif
      endfor
    %}

    {% if slide_count > 0 %}
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign link_key = 'slide_' | append: i | append: '_link'
          assign alt_key = 'slide_' | append: i | append: '_alt_text'
          
          assign slide_image = block.settings[image_key]
          assign slide_link = block.settings[link_key]
          assign slide_alt = block.settings[alt_key]
        %}

        {% if slide_image %}
          <div class="ai-hero-slider-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}">
            {% if slide_link != blank %}
              <a href="{{ slide_link }}" class="ai-hero-slider-link-{{ ai_gen_id }}">
                <img
                  src="{{ slide_image | image_url: width: 2000 }}"
                  alt="{{ slide_alt | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                  class="ai-hero-slider-image-{{ ai_gen_id }}"
                >
              </a>
            {% else %}
              <img
                src="{{ slide_image | image_url: width: 2000 }}"
                alt="{{ slide_alt | escape }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-hero-slider-image-{{ ai_gen_id }}"
              >
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% if block.settings.show_navigation and slide_count > 1 %}
        <button class="ai-hero-slider-nav-{{ ai_gen_id }} ai-hero-slider-nav-prev-{{ ai_gen_id }}" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="ai-hero-slider-nav-{{ ai_gen_id }} ai-hero-slider-nav-next-{{ ai_gen_id }}" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}

      {% if block.settings.show_pagination and slide_count > 1 %}
        <div class="ai-hero-slider-pagination-{{ ai_gen_id }}">
          {% for i in (1..slide_count) %}
            <button class="ai-hero-slider-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div class="ai-hero-slider-slide-{{ ai_gen_id }} active">
        <div class="ai-hero-slider-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-slider-empty-state-{{ ai_gen_id }}">
            Add images to create your hero slider
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</hero-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.touchStartX = 0;
        this.touchEndX = 0;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-hero-slider-slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-hero-slider-dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-hero-slider-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-hero-slider-nav-next-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;
        this.transitionEffect = this.dataset.transition;

        if (this.slides.length <= 1) return;

        this.setupEventListeners();
        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('touchstart', (e) => {
          this.touchStartX = e.changedTouches[0].screenX;
        });

        this.addEventListener('touchend', (e) => {
          this.touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe();
        });

        this.addEventListener('mouseenter', () => {
          if (this.autoplay) {
            this.stopAutoplay();
          }
        });

        this.addEventListener('mouseleave', () => {
          if (this.autoplay) {
            this.startAutoplay();
          }
        });
      }

      handleSwipe() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.nextSlide();
          } else {
            this.previousSlide();
          }
        }
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }

        if (this.autoplay) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('hero-slider-{{ ai_gen_id }}', HeroSlider{{ ai_gen_id }});
  })();
</script>

