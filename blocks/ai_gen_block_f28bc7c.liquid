{% doc %}
  @prompt
    Act as an expert frontend developer. Build a fully responsive, touch-friendly image slider/slideshow component from scratch using [Insert your stack here, e.g., HTML/CSS/JS or React or Shopify Liquid].
    
    The absolute highest priority is fixing mobile cropping. The component must meet these strict requirements:
    
    1. Responsive Image Swapping:
       - Provide two separate image inputs for each slide: one for Desktop (landscape aspect ratio, e.g., 16:9 or 21:9) and one for Mobile (portrait aspect ratio, e.g., 4:5 or 9:16).
       - Use the HTML5 `<picture>` tag with `srcset` and `media` queries (or CSS background-image media queries) to automatically load the mobile image on screens smaller than 768px, and the desktop image on larger screens.
       - Do not just hide one with `display: none`; ensure only the correct image resource loads to optimize performance.
    
    2. Aspect Ratio & Fit:
       - Use modern CSS rules (`object-fit: cover` or `aspect-ratio`) to ensure that even if the container shifts slightly, the images never warp, stretch, or experience critical text/subject cropping.
    
    3. Slider Behavior & Controls:
       - Smooth horizontal transitions (CSS transitions or hardware-accelerated transforms).
       - Clean navigation dots at the bottom and overlayed left/right arrow buttons.
       - For mobile, implement native touch-swipe gestures.
    
    4. Overlay Content:
       - An optional text overlay container (Heading, Subheading, Call-to-Action Button) on each slide.
       - On desktop, this overlay should align beautifully (e.g., left-aligned or centered).
       - On mobile, the text must stack cleanly below or scale down gracefully so it never covers up the core visual elements of the mobile image.
    
    Please provide clean, semantic, well-commented code split into structural markup, styling, and any necessary lightweight script.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slider-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slider-viewport-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  .ai-slider-slide-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
  }

  .ai-slider-picture-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 0;
    padding-bottom: {{ block.settings.desktop_aspect_ratio }}%;
    position: relative;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  @media screen and (max-width: 767px) {
    .ai-slider-picture-{{ ai_gen_id }} {
      padding-bottom: {{ block.settings.mobile_aspect_ratio }}%;
    }
  }

  .ai-slider-picture-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .ai-slider-picture-{{ ai_gen_id }} .ai-slider-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-slider-picture-{{ ai_gen_id }} .ai-slider-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-slider-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
    padding: 40px;
    z-index: 2;
  }

  @media screen and (max-width: 767px) {
    .ai-slider-overlay-{{ ai_gen_id }} {
      padding: 20px;
      {% if block.settings.mobile_content_position == 'below' %}
        position: static;
        background-color: {{ block.settings.mobile_content_background }};
      {% endif %}
    }
  }

  .ai-slider-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 767px) {
    .ai-slider-content-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }

  .ai-slider-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 767px) {
    .ai-slider-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin: 0 0 12px;
    }
  }

  .ai-slider-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    line-height: 1.5;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 767px) {
    .ai-slider-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.85 }}px;
      margin: 0 0 16px;
    }
  }

  .ai-slider-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-slider-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 767px) {
    .ai-slider-button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }

  .ai-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: {{ block.settings.arrow_opacity | divided_by: 100.0 }};
  }

  .ai-slider-nav-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.arrow_hover_background }};
  }

  .ai-slider-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-slider-nav-prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-slider-nav-next-{{ ai_gen_id }} {
    right: 20px;
  }

  @media screen and (max-width: 767px) {
    .ai-slider-nav-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size | times: 0.8 }}px;
      height: {{ block.settings.arrow_size | times: 0.8 }}px;
    }

    .ai-slider-nav-prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-slider-nav-next-{{ ai_gen_id }} {
      right: 10px;
    }
  }

  .ai-slider-nav-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .ai-slider-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  @media screen and (max-width: 767px) {
    .ai-slider-dots-{{ ai_gen_id }} {
      bottom: 10px;
      gap: 8px;
    }
  }

  .ai-slider-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: {{ block.settings.dot_opacity | divided_by: 100.0 }};
    padding: 0;
  }

  .ai-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
    transform: scale(1.2);
  }

  @media screen and (max-width: 767px) {
    .ai-slider-dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size | times: 0.8 }}px;
      height: {{ block.settings.dot_size | times: 0.8 }}px;
    }
  }

  .ai-slider-autoplay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 3;
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: {{ block.settings.arrow_opacity | divided_by: 100.0 }};
  }

  .ai-slider-autoplay-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.arrow_hover_background }};
  }

  @media screen and (max-width: 767px) {
    .ai-slider-autoplay-{{ ai_gen_id }} {
      width: 32px;
      height: 32px;
      bottom: 10px;
      right: 10px;
    }
  }

  .ai-slider-autoplay-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }
{% endstyle %}

<image-slider-{{ ai_gen_id }} class="ai-slider-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slider-viewport-{{ ai_gen_id }}">
    <div class="ai-slider-track-{{ ai_gen_id }}" data-slider-track>
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign desktop_image_key = 'slide_' | append: i | append: '_desktop_image'
          assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign subheading_key = 'slide_' | append: i | append: '_subheading'
          assign button_text_key = 'slide_' | append: i | append: '_button_text'
          assign button_link_key = 'slide_' | append: i | append: '_button_link'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign desktop_image = block.settings[desktop_image_key]
          assign mobile_image = block.settings[mobile_image_key]
          assign heading = block.settings[heading_key]
          assign subheading = block.settings[subheading_key]
          assign button_text = block.settings[button_text_key]
          assign button_link = block.settings[button_link_key]
        %}

        {% if slide_enabled %}
          <div class="ai-slider-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
            <picture class="ai-slider-picture-{{ ai_gen_id }}">
              {% if mobile_image != blank %}
                <source
                  media="(max-width: 767px)"
                  srcset="{{ mobile_image | image_url: width: 800 }} 800w,
                          {{ mobile_image | image_url: width: 1200 }} 1200w"
                  sizes="100vw"
                >
              {% endif %}

              {% if desktop_image != blank %}
                <source
                  media="(min-width: 768px)"
                  srcset="{{ desktop_image | image_url: width: 1200 }} 1200w,
                          {{ desktop_image | image_url: width: 1800 }} 1800w,
                          {{ desktop_image | image_url: width: 2400 }} 2400w"
                  sizes="100vw"
                >
                <img
                  src="{{ desktop_image | image_url: width: 1800 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  loading="lazy"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                >
              {% else %}
                <div class="ai-slider-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </picture>

            {% if block.settings.mobile_content_position == 'overlay' or forloop.index0 == 0 %}
              <div class="ai-slider-overlay-{{ ai_gen_id }}">
                <div class="ai-slider-content-{{ ai_gen_id }}">
                  {% if heading != blank %}
                    <h2 class="ai-slider-heading-{{ ai_gen_id }}">{{ heading }}</h2>
                  {% endif %}

                  {% if subheading != blank %}
                    <p class="ai-slider-subheading-{{ ai_gen_id }}">{{ subheading }}</p>
                  {% endif %}

                  {% if button_text != blank %}
                    <a
                      href="{{ button_link | default: '#' }}"
                      class="ai-slider-button-{{ ai_gen_id }}"
                    >
                      {{ button_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            {% endif %}

            {% if block.settings.mobile_content_position == 'below' %}
              <div class="ai-slider-overlay-{{ ai_gen_id }}" style="display: none;">
                <div class="ai-slider-content-{{ ai_gen_id }}">
                  {% if heading != blank %}
                    <h2 class="ai-slider-heading-{{ ai_gen_id }}">{{ heading }}</h2>
                  {% endif %}

                  {% if subheading != blank %}
                    <p class="ai-slider-subheading-{{ ai_gen_id }}">{{ subheading }}</p>
                  {% endif %}

                  {% if button_text != blank %}
                    <a
                      href="{{ button_link | default: '#' }}"
                      class="ai-slider-button-{{ ai_gen_id }}"
                    >
                      {{ button_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if block.settings.show_arrows %}
    <button
      class="ai-slider-nav-{{ ai_gen_id }} ai-slider-nav-prev-{{ ai_gen_id }}"
      data-slider-prev
      aria-label="Previous slide"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-slider-nav-{{ ai_gen_id }} ai-slider-nav-next-{{ ai_gen_id }}"
      data-slider-next
      aria-label="Next slide"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  {% endif %}

  {% if block.settings.show_dots %}
    <div class="ai-slider-dots-{{ ai_gen_id }}" data-slider-dots></div>
  {% endif %}

  {% if block.settings.autoplay %}
    <button
      class="ai-slider-autoplay-{{ ai_gen_id }}"
      data-slider-autoplay
      aria-label="Toggle autoplay"
    >
      <svg data-play-icon xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="5 3 19 12 5 21 5 3"></polygon>
      </svg>
      <svg data-pause-icon style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="6" y="4" width="4" height="16"></rect>
        <rect x="14" y="4" width="4" height="16"></rect>
      </svg>
    </button>
  {% endif %}
</image-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = 0;
        this.autoplayInterval = null;
        this.isAutoplayActive = {{ block.settings.autoplay }};
        this.touchStartX = 0;
        this.touchEndX = 0;
        this.isDragging = false;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-slider-track]');
        this.slides = this.querySelectorAll('[data-slide-index]');
        this.prevButton = this.querySelector('[data-slider-prev]');
        this.nextButton = this.querySelector('[data-slider-next]');
        this.dotsContainer = this.querySelector('[data-slider-dots]');
        this.autoplayButton = this.querySelector('[data-slider-autoplay]');

        this.totalSlides = this.slides.length;

        if (this.totalSlides === 0) return;

        this.setupDots();
        this.setupEventListeners();
        this.updateSlider();

        if (this.isAutoplayActive) {
          this.startAutoplay();
        }

        this.setupMobileContentPosition();
      }

      setupMobileContentPosition() {
        const mobileContentPosition = '{{ block.settings.mobile_content_position }}';
        if (mobileContentPosition === 'below' && window.innerWidth <= 767) {
          this.slides.forEach(slide => {
            const overlay = slide.querySelector('.ai-slider-overlay-{{ ai_gen_id }}');
            if (overlay && overlay.style.display === 'none') {
              overlay.style.display = 'flex';
            }
          });
        }
      }

      setupDots() {
        if (!this.dotsContainer) return;

        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-slider-dot-{{ ai_gen_id }}';
          dot.setAttribute('data-dot-index', i);
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          if (i === 0) dot.classList.add('active');
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.goToPrevSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.goToNextSlide());
        }

        if (this.dotsContainer) {
          this.dotsContainer.addEventListener('click', (e) => {
            const dot = e.target.closest('[data-dot-index]');
            if (dot) {
              const index = parseInt(dot.getAttribute('data-dot-index'));
              this.goToSlide(index);
            }
          });
        }

        if (this.autoplayButton) {
          this.autoplayButton.addEventListener('click', () => this.toggleAutoplay());
        }

        this.track.addEventListener('touchstart', (e) => this.handleTouchStart(e), { passive: true });
        this.track.addEventListener('touchmove', (e) => this.handleTouchMove(e), { passive: true });
        this.track.addEventListener('touchend', () => this.handleTouchEnd());

        this.track.addEventListener('mousedown', (e) => this.handleMouseDown(e));
        this.track.addEventListener('mousemove', (e) => this.handleMouseMove(e));
        this.track.addEventListener('mouseup', () => this.handleMouseUp());
        this.track.addEventListener('mouseleave', () => this.handleMouseUp());

        window.addEventListener('resize', () => this.setupMobileContentPosition());
      }

      handleTouchStart(e) {
        this.touchStartX = e.touches[0].clientX;
        this.stopAutoplay();
      }

      handleTouchMove(e) {
        this.touchEndX = e.touches[0].clientX;
      }

      handleTouchEnd() {
        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.goToNextSlide();
          } else {
            this.goToPrevSlide();
          }
        }

        this.touchStartX = 0;
        this.touchEndX = 0;
      }

      handleMouseDown(e) {
        this.isDragging = true;
        this.touchStartX = e.clientX;
        this.track.style.cursor = 'grabbing';
        this.stopAutoplay();
      }

      handleMouseMove(e) {
        if (!this.isDragging) return;
        this.touchEndX = e.clientX;
      }

      handleMouseUp() {
        if (!this.isDragging) return;

        const swipeThreshold = 50;
        const diff = this.touchStartX - this.touchEndX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.goToNextSlide();
          } else {
            this.goToPrevSlide();
          }
        }

        this.isDragging = false;
        this.touchStartX = 0;
        this.touchEndX = 0;
        this.track.style.cursor = 'grab';
      }

      goToPrevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.totalSlides) % this.totalSlides;
        this.updateSlider();
      }

      goToNextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.totalSlides;
        this.updateSlider();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
        this.stopAutoplay();
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.ai-slider-dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === this.currentSlide);
          });
        }

        if (this.prevButton) {
          this.prevButton.disabled = false;
        }

        if (this.nextButton) {
          this.nextButton.disabled = false;
        }
      }

      startAutoplay() {
        this.isAutoplayActive = true;
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);

        if (this.autoplayButton) {
          this.autoplayButton.querySelector('[data-play-icon]').style.display = 'none';
          this.autoplayButton.querySelector('[data-pause-icon]').style.display = 'block';
        }
      }

      stopAutoplay() {
        this.isAutoplayActive = false;
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }

        if (this.autoplayButton) {
          this.autoplayButton.querySelector('[data-play-icon]').style.display = 'block';
          this.autoplayButton.querySelector('[data-pause-icon]').style.display = 'none';
        }
      }

      toggleAutoplay() {
        if (this.isAutoplayActive) {
          this.stopAutoplay();
        } else {
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('image-slider-{{ ai_gen_id }}', ImageSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Responsive image slider",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_aspect_ratio",
      "label": "Desktop aspect ratio",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 45,
      "info": "Lower values create wider images (16:9 ≈ 56%, 21:9 ≈ 43%)"
    },
    {
      "type": "range",
      "id": "mobile_aspect_ratio",
      "label": "Mobile aspect ratio",
      "min": 80,
      "max": 180,
      "step": 5,
      "unit": "%",
      "default": 125,
      "info": "Higher values create taller images (4:5 = 125%, 9:16 ≈ 178%)"
    },
    {
      "type": "header",
      "content": "Content overlay"
    },
    {
      "type": "select",
      "id": "content_vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
