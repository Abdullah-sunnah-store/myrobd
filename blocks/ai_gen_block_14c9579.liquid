    }
    .ai-reviews-slider__title-{{ ai_gen_id }} {
      white-space: wrap;
    }

    .ai-reviews-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<customer-reviews-slider-{{ ai_gen_id }} class="ai-reviews-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-slider__container-{{ ai_gen_id }}">
    <div class="ai-reviews-slider__header-{{ ai_gen_id }}">
      <div class="ai-reviews-slider__header-line-{{ ai_gen_id }}"></div>
      <h2 class="ai-reviews-slider__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      <div class="ai-reviews-slider__header-line-{{ ai_gen_id }}"></div>
    </div>

    <div class="ai-reviews-slider__wrapper-{{ ai_gen_id }}">
      <div class="ai-reviews-slider__track-{{ ai_gen_id }}" data-track>
        {% for i in (1..10) %}
          {% liquid
            assign profile_key = 'profile_picture_' | append: i
            assign name_key = 'customer_name_' | append: i
            assign photo_key = 'review_photo_' | append: i
            assign rating_key = 'star_rating_' | append: i
            assign text_key = 'review_text_' | append: i

            assign profile_picture = block.settings[profile_key]
            assign customer_name = block.settings[name_key]
            assign review_photo = block.settings[photo_key]
            assign star_rating = block.settings[rating_key]
            assign review_text = block.settings[text_key]
          %}

          {% if customer_name != blank %}
            <div class="ai-reviews-slider__slide-{{ ai_gen_id }}">
              <div class="ai-reviews-slider__card-{{ ai_gen_id }}">
                <div class="ai-reviews-slider__profile-wrapper-{{ ai_gen_id }}">
                  {% if profile_picture %}
                    <img
                      src="{{ profile_picture | image_url: width: 200 }}"
                      alt="{{ customer_name | escape }}"
                      class="ai-reviews-slider__profile-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="200"
                      height="200"
                    >
                  {% else %}
                    <div class="ai-reviews-slider__profile-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <h3 class="ai-reviews-slider__name-{{ ai_gen_id }}">{{ customer_name }}</h3>

                <div class="ai-reviews-slider__review-image-wrapper-{{ ai_gen_id }}">
                  {% if review_photo %}
                    <img
                      src="{{ review_photo | image_url: width: 600 }}"
                      alt="Review by {{ customer_name | escape }}"
                      class="ai-reviews-slider__review-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="300"
                    >
                  {% else %}
                    <div class="ai-reviews-slider__review-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-reviews-slider__stars-{{ ai_gen_id }}">
                  {% for j in (1..5) %}
                    <svg
                      class="ai-reviews-slider__star-{{ ai_gen_id }} {% if j > star_rating %}ai-reviews-slider__star-empty-{{ ai_gen_id }}{% endif %}"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endfor %}
                </div>

                <p class="ai-reviews-slider__text-{{ ai_gen_id }}">{{ review_text }}</p>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <button
        class="ai-reviews-slider__nav-{{ ai_gen_id }} ai-reviews-slider__nav-prev-{{ ai_gen_id }}"
        data-prev
        aria-label="Previous review"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
        </svg>
      </button>

      <button
        class="ai-reviews-slider__nav-{{ ai_gen_id }} ai-reviews-slider__nav-next-{{ ai_gen_id }}"
        data-next
        aria-label="Next review"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
        </svg>
      </button>
    </div>
  </div>
</customer-reviews-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomerReviewsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.slides = this.querySelectorAll('.ai-reviews-slider__slide-{{ ai_gen_id }}');
        this.slidesPerView = 5;
      }

      connectedCallback() {
        if (this.slides.length === 0) return;
        
        this.updateSlidesPerView();
        this.setupEventListeners();
        window.addEventListener('resize', () => this.updateSlidesPerView());
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = 1;
        } else if (width <= 989) {
          this.slidesPerView = 2;
        } else {
          this.slidesPerView = 5;
        }
        this.updateSlider();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      next() {
        const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      updateSlider() {
        if (this.slides.length === 0) return;
        
        const slideWidth = this.slides[0].offsetWidth;
        const gap = 20;
        const offset = -(this.currentIndex * (slideWidth + gap));
        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevButton && this.nextButton) {
          this.prevButton.style.opacity = this.currentIndex === 0 ? '0.5' : '1';
          this.prevButton.style.cursor = this.currentIndex === 0 ? 'not-allowed' : 'pointer';

          const maxIndex = Math.max(0, this.slides.length - this.slidesPerView);
          this.nextButton.style.opacity = this.currentIndex >= maxIndex ? '0.5' : '1';
          this.nextButton.style.cursor = this.currentIndex >= maxIndex ? 'not-allowed' : 'pointer';
        }
      }
    }

    customElements.define('customer-reviews-slider-{{ ai_gen_id }}', CustomerReviewsSlider{{ ai_gen_id }});
  })();
</script>

