{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-live-viewer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-live-viewer-container-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: nowrap;
  }

  .ai-live-viewer-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background-color: {{ block.settings.badge_background_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
  }

  .ai-live-viewer-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-live-viewer-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ block.settings.icon_color }};
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-live-viewer-count-{{ ai_gen_id }} {
    color: {{ block.settings.number_color }};
    font-size: {{ block.settings.number_font_size }}px;
    font-weight: 600;
    line-height: 1;
    transition: opacity 0.3s ease;
  }

  .ai-live-viewer-count-{{ ai_gen_id }}.fade {
    opacity: 0;
  }

  .ai-live-viewer-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size }}px;
    font-weight: 400;
    line-height: 1.4;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .ai-live-viewer-container-{{ ai_gen_id }} {
      gap: 6px;
    }

    .ai-live-viewer-badge-{{ ai_gen_id }} {
      padding: 5px 10px;
      gap: 5px;
    }

    .ai-live-viewer-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }

    .ai-live-viewer-count-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_font_size | times: 0.9 }}px;
    }

    .ai-live-viewer-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<live-viewer-counter-{{ ai_gen_id }}
  class="ai-live-viewer-{{ ai_gen_id }}"
  data-min="{{ block.settings.min_viewers }}"
  data-max="{{ block.settings.max_viewers }}"
  data-interval="{{ block.settings.update_interval }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-live-viewer-container-{{ ai_gen_id }}">
    <div class="ai-live-viewer-badge-{{ ai_gen_id }}">
      <div class="ai-live-viewer-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </div>
      <span class="ai-live-viewer-count-{{ ai_gen_id }}">0</span>
    </div>
    <span class="ai-live-viewer-text-{{ ai_gen_id }}">{{ block.settings.viewer_text }}</span>
  </div>
</live-viewer-counter-{{ ai_gen_id }}>

<script>
  (function() {
    class LiveViewerCounter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countElement = null;
        this.intervalId = null;
        this.min = 15;
        this.max = 250;
        this.interval = 10000;
      }

      connectedCallback() {
        this.countElement = this.querySelector('.ai-live-viewer-count-{{ ai_gen_id }}');
        this.min = parseInt(this.dataset.min) || 5;
        this.max = parseInt(this.dataset.max) || 25;
        this.interval = parseInt(this.dataset.interval) * 1000 || 10000;

        this.updateCount();
        this.startInterval();
      }

      disconnectedCallback() {
        if (this.intervalId) {
          clearInterval(this.intervalId);
        }
      }

      getRandomNumber() {
        return Math.floor(Math.random() * (this.max - this.min + 1)) + this.min;
      }

      updateCount() {
        if (!this.countElement) return;

        this.countElement.classList.add('fade');

        setTimeout(() => {
          const newCount = this.getRandomNumber();
          this.countElement.textContent = newCount;
          this.countElement.classList.remove('fade');
        }, 300);
      }

      startInterval() {
        this.intervalId = setInterval(() => {
          this.updateCount();
        }, this.interval);
      }
    }

    customElements.define('live-viewer-counter-{{ ai_gen_id }}', LiveViewerCounter{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Live viewer counter",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "viewer_text",
      "label": "Text",
      "default": "People are currently viewing this"
    },
    {
      "type": "header",
      "content": "Viewer settings"
    },
    {
      "type": "range",
      "id": "min_viewers",
      "label": "Minimum viewers",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "max_viewers",
      "label": "Maximum viewers",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 25
    },
    {
      "type": "range",
      "id": "update_interval",
      "label": "Update interval",
      "min": 5,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 10
    },
    {
      "type": "header",
      "content": "Badge style"
    },
    {
      "type": "color",
      "id": "badge_background_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "badge_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Icon and number"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Number color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "number_font_size",
      "label": "Number size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Live viewer counter"
    }
  ]
}
{% endschema %}