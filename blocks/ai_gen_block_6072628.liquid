{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-menu-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px 0;
  }

  .ai-category-menu__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: {{ block.settings.item_gap_desktop }}px;
    padding: 0 20px;
  }

  .ai-category-menu__link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .ai-category-menu__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-category-menu__container-{{ ai_gen_id }} {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      gap: {{ block.settings.item_gap_mobile }}px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    .ai-category-menu__container-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }
  }
{% endstyle %}

<category-menu-{{ ai_gen_id }} class="ai-category-menu-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <nav class="ai-category-menu__container-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% assign label_key = 'menu_item_' | append: i | append: '_label' %}
      {% assign link_key = 'menu_item_' | append: i | append: '_link' %}
      {% assign label = block.settings[label_key] %}
      {% assign link = block.settings[link_key] %}
      
      {% if label != blank %}
        <a 
          href="{{ link }}" 
          class="ai-category-menu__link-{{ ai_gen_id }}"
        >
          {{ label }}
        </a>
      {% endif %}
    {% endfor %}
  </nav>
</category-menu-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryMenu{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-category-menu__container-{{ ai_gen_id }}');
      }
    }

    customElements.define('category-menu-{{ ai_gen_id }}', CategoryMenu{{ ai_gen_id }});
  })();
</script>

