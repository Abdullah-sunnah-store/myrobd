
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-store-locations-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-store-locations__heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-store-locations__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-store-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-store-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 {{ block.settings.shadow_vertical | plus: 4 }}px {{ block.settings.shadow_blur | plus: 8 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | times: 1.5 }});
  }

  .ai-store-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
  }

  .ai-store-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-store-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-store-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-store-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    right: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-store-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-store-card__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.store_name_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: {{ block.settings.text_color }};
    letter-spacing: 0.5px;
  }

  .ai-store-card__info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-store-card__info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: {{ block.settings.info_font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-store-card__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }

  .ai-store-card__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-store-card__address-{{ ai_gen_id }} {
    color: {{ block.settings.address_color }};
  }

  .ai-store-card__address-{{ ai_gen_id }} a {
    color: {{ block.settings.address_color }};
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ai-store-card__address-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  .ai-store-card__phone-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ai-store-card__phone-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 989px) {
    .ai-store-locations__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-store-locations__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-store-locations__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
      margin-bottom: 30px;
    }

    .ai-store-card__image-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<store-locations-{{ ai_gen_id }} class="ai-store-locations-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-store-locations__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-store-locations__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-store-locations__grid-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign store_enabled_key = 'store_' | append: i | append: '_enabled'
          assign store_image_key = 'store_' | append: i | append: '_image'
          assign store_name_key = 'store_' | append: i | append: '_name'
          assign show_badge_key = 'store_' | append: i | append: '_show_badge'
          assign badge_text_key = 'store_' | append: i | append: '_badge_text'
          assign address_key = 'store_' | append: i | append: '_address'
          assign maps_link_key = 'store_' | append: i | append: '_maps_link'
          assign hours_key = 'store_' | append: i | append: '_hours'
          assign phone_key = 'store_' | append: i | append: '_phone'

          assign store_enabled = block.settings[store_enabled_key]
          assign store_image = block.settings[store_image_key]
          assign store_name = block.settings[store_name_key]
          assign show_badge = block.settings[show_badge_key]
          assign badge_text = block.settings[badge_text_key]
          assign address = block.settings[address_key]
          assign maps_link = block.settings[maps_link_key]
          assign hours = block.settings[hours_key]
          assign phone = block.settings[phone_key]
        %}

        {% if store_enabled %}
          <div class="ai-store-card-{{ ai_gen_id }}">
            <div class="ai-store-card__image-wrapper-{{ ai_gen_id }}">
              {% if store_image %}
                <img
                  src="{{ store_image | image_url: width: 800 }}"
                  alt="{{ store_name | escape }}"
                  loading="lazy"
                  width="800"
                  height="{{ block.settings.image_height }}"
                  class="ai-store-card__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-store-card__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if show_badge and badge_text != blank %}
                <div class="ai-store-card__badge-{{ ai_gen_id }}">
                  {{ badge_text }}
                </div>
              {% endif %}
            </div>

            <div class="ai-store-card__content-{{ ai_gen_id }}">
              {% if store_name != blank %}
                <h3 class="ai-store-card__name-{{ ai_gen_id }}">{{ store_name }}</h3>
              {% endif %}

              <div class="ai-store-card__info-{{ ai_gen_id }}">
                {% if address != blank %}
                  <div class="ai-store-card__info-item-{{ ai_gen_id }}">
                    <div class="ai-store-card__icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.address_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                      </svg>
                    </div>
                    <div class="ai-store-card__address-{{ ai_gen_id }}">
                      {% if maps_link != blank %}
                        <a href="{{ maps_link }}" target="_blank" rel="noopener">
                          {{ address }}
                        </a>
                      {% else %}
                        {{ address }}
                      {% endif %}
                    </div>
                  </div>
                {% endif %}

                {% if hours != blank %}
                  <div class="ai-store-card__info-item-{{ ai_gen_id }}">
                    <div class="ai-store-card__icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.text_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                      </svg>
                    </div>
                    <div>{{ hours }}</div>
                  </div>
                {% endif %}

                {% if phone != blank %}
                  <div class="ai-store-card__info-item-{{ ai_gen_id }} ai-store-card__phone-{{ ai_gen_id }}">
                    <div class="ai-store-card__icon-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.text_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                      </svg>
                    </div>
                    <div>
                      <a href="tel:{{ phone | replace: ' ', '' | replace: '-', '' }}">
                        {{ phone }}
                      </a>
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</store-locations-{{ ai_gen_id }}>

<script>
  {% comment %} (function() {
    class StoreLocations{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeCards();
      }

      initializeCards() {
        const cards = this.querySelectorAll('.ai-store-card-{{ ai_gen_id }}');
        cards.forEach((card) => {
          card.addEventListener('mouseenter', function() {
            this.style.zIndex = '10';
          });
          card.addEventListener('mouseleave', function() {
            this.style.zIndex = '1';
          });
        });
      }
    }

    customElements.define('store-locations-{{ ai_gen_id }}', StoreLocations{{ ai_gen_id }});
  })(); {% endcomment %}
</script>

